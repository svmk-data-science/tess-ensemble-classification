ow1 col3\" >193</td>\n","    </tr>\n","    <tr>\n","      <th id=\"T_80c21_level0_row2\" class=\"row_heading level0 row2\" >accuracy</th>\n","      <td id=\"T_80c21_row2_col0\" class=\"data row2 col0\" >0.86</td>\n","      <td id=\"T_80c21_row2_col1\" class=\"data row2 col1\" >0.86</td>\n","      <td id=\"T_80c21_row2_col2\" class=\"data row2 col2\" >0.86</td>\n","      <td id=\"T_80c21_row2_col3\" class=\"data row2 col3\" >1</td>\n","    </tr>\n","    <tr>\n","      <th id=\"T_80c21_level0_row3\" class=\"row_heading level0 row3\" >macro avg</th>\n","      <td id=\"T_80c21_row3_col0\" class=\"data row3 col0\" >0.86</td>\n","      <td id=\"T_80c21_row3_col1\" class=\"data row3 col1\" >0.86</td>\n","      <td id=\"T_80c21_row3_col2\" class=\"data row3 col2\" >0.86</td>\n","      <td id=\"T_80c21_row3_col3\" class=\"data row3 col3\" >411</td>\n","    </tr>\n","    <tr>\n","      <th id=\"T_80c21_level0_row4\" class=\"row_heading level0 row4\" >weighted avg</th>\n","      <td id=\"T_80c21_row4_col0\" class=\"data row4 col0\" >0.86</td>\n","      <td id=\"T_80c21_row4_col1\" class=\"data row4 col1\" >0.86</td>\n","      <td id=\"T_80c21_row4_col2\" class=\"data row4 col2\" >0.86</td>\n","      <td id=\"T_80c21_row4_col3\" class=\"data row4 col3\" >411</td>\n","    </tr>\n","  </tbody>\n","</table>\n"],"text/plain":["<pandas.io.formats.style.Styler at 0x7a0f97550080>"]},"metadata":{},"output_type":"display_data"},{"data":{"text/plain":["<Figure size 1600x1600 with 0 Axes>"]},"metadata":{},"output_type":"display_data"}],"source":["# STYLE THE DATAFRAME\n","styled_report = df_report.style \\\n","    .background_gradient(cmap='YlGnBu') \\\n","    .set_caption('RF - Classification Report') \\\n","    .format({'precision': '{:.2f}', 'recall': '{:.2f}', 'f1-score': '{:.2f}', 'support': '{:.0f}'}) \\\n","    .set_properties(**{'text-align': 'center'}) \\\n","    .set_table_styles([{\n","        'selector': 'caption',\n","        'props': 'caption-side: top; font-size: 16px; font-weight: bold;'\n","    }])\n","\n","\n","plt.figure(figsize=(16, 16))\n","display(styled_report)"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"background_save":true},"id":"ijmxiz3fuHa3","outputId":"a6b42ca1-1f88-40da-c5ea-5c760e172869"},"outputs":[{"data":{"image/png":"\n","text/plain":["<Figure size 640x480 with 2 Axes>"]},"metadata":{},"output_type":"display_data"}],"source":["# CREATE A CONFUSION MATRIX WITH CUSTOM LABELS\n","cm_RF_clf_opt = confusion_matrix(y_test, y_predict_RF_opt)\n","\n","disp = ConfusionMatrixDisplay(confusion_matrix=cm_RF_clf_opt, display_labels=['FALSE POSITIVE', 'CONFIRMED'])\n","\n","# PLOT THE CONFUSION MATRIX\n","disp.plot(cmap='Purples')\n","plt.show()"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"background_save":true},"id":"2U30XNoEub71"},"outputs":[],"source":["# ROC CURVE\n","\n","# PREDICT PROBABILITIES\n","y_prob = model_RF_opt.predict_proba(X_test_scaled)[:, 1]\n","\n","# COMPUTE ROC CURVE AND AREA\n","fpr, tpr, _ = roc_curve(y_test, y_prob)\n","roc_auc = auc(fpr, tpr)"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"background_save":true},"id":"TLZrDyuGuf5K","outputId":"ab192110-df84-4237-b05e-e02b6ba0da26"},"outputs":[{"data":{"image/png":"\n","text/plain":["<Figure size 640x480 with 1 Axes>"]},"metadata":{},"output_type":"display_data"}],"source":["# PLOT ROC CURVE\n","\n","plt.figure()\n","plt.plot(fpr, tpr, color='darkorange', lw=2, label='ROC curve (area = %0.2f)' % roc_auc)\n","plt.plot([0, 1], [0, 1], color='navy', lw=2, linestyle='--')\n","plt.xlim([0.0, 1.0])\n","plt.ylim([0.0, 1.05])\n","plt.xlabel('False Positive Rate')\n","plt.ylabel('True Positive Rate')\n","plt.title('Receiver Operating Characteristic')\n","plt.legend(loc=\"lower right\")\n","plt.show()"]},{"cell_type":"markdown","metadata":{"id":"1Dd6tke8vaDG"},"source":["**APPLY SHAP ANALYSIS**\n"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"background_save":true,"referenced_widgets":["2912eb38d54e4ba7b6f99dae7c84d501"]},"id":"JIt1mRM7w8PE","outputId":"39bbf951-c0dc-4273-f194-bbf26fd215a1"},"outputs":[{"data":{"application/vnd.jupyter.widget-view+json":{"model_id":"2912eb38d54e4ba7b6f99dae7c84d501","version_major":2,"version_minor":0},"text/plain":["  0%|          | 0/100 [00:00<?, ?it/s]"]},"metadata":{},"output_type":"display_data"},{"data":{"image/png":"\n","text/plain":["<Figure size 800x950 with 2 Axes>"]},"metadata":{},"output_type":"display_data"}],"source":["import shap\n","import matplotlib.pyplot as plt\n","\n","# ⚙️ USE THE ORIGINAL SVM TRAINED ON SCALED FEATURES (BEFORE PCA)\n","best_RF = grid_RF_opt.best_estimator_.named_steps['randomforestclassifier']\n","\n","# 💬 USE KERNEL EXPLAINER (MODEL-AGNOSTIC) FOR SVM\n","explainer = shap.KernelExplainer(best_RF.predict, X_test_scaled[:100])  # use a sample subset for background\n","shap_values = explainer.shap_values(X_test_scaled[:100])  # explanation on test set subset\n","\n","# 📊 SUMMARY PLOT: GLOBAL FEATURE IMPORTANCE\n","shap.summary_plot(shap_values, X_test_scaled[:100], feature_names= df_X_test_scaled.columns)\n"]}],"metadata":{"colab":{"provenance":[],"authorship_tag":"ABX9TyPpkQonzuRbQb3HfLMDcHvI"},"kernelspec":{"display_name":"Python 3","name":"python3"},"language_info":{"name":"python"}},"nbformat":4,"nbformat_minor":0}